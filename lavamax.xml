 45:   Future<void> _editMaxCredits() async {
 46:     final ctrl =
 47:         TextEditingController(text: _maxCredits.toString());
 48:     final result = await showDialog<int>(
 49:       context: context,
 50:       builder: (_) => AlertDialog(
 51:         title: const Text('Limite de creditos por cliente'),
 52:         content: TextField(
 53:           controller: ctrl,
 54:           keyboardType: TextInputType.number,
 55:           decoration: const InputDecoration(
 56:             labelText: 'Maximo de creditos ativos',
 57:           ),
 58:         ),
 59:         actions: [
 60:           TextButton(
 61:             onPressed: () => Navigator.pop(context),
 62:             child: const Text('Cancelar'),
 63:           ),
 64:           FilledButton(
 65:             onPressed: () {
 66:               final v = int.tryParse(ctrl.text.trim());
 67:               if (v != null && v > 0) Navigator.pop(context, v);
 68:             },
 69:             child: const Text('Salvar'),
 70:           ),
 71:         ],
 72:       ),
 73:     );
 74:     if (result != null) {
 75:       await _repo.setMaxCredits(result);
 76:       if (mounted) setState(() => _maxCredits = result);
 77:       if (mounted) {
 78:         ScaffoldMessenger.of(context).showSnackBar(
 79:           SnackBar(content: Text('Limite atualizado para $result.')),
 80:         );
 81:       }
 82:     }
 83:   }
 84:   Future<void> _toggleCredit(CreditModel credit) async {
 85:     final isActive = credit.status == 'active';
 86:     final action = isActive ? 'cancelar' : 'reativar';
 87:     final confirm = await showDialog<bool>(
 88:       context: context,
 89:       builder: (_) => AlertDialog(
 90:         title: Text('${isActive ? 'Cancelar' : 'Reativar'} credito'),
