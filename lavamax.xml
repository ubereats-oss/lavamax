<file path="storage.rules">
 1: rules_version = '2';
 2: // Craft rules based on data in your Firestore database
 3: // allow write: if firestore.get(
 4: //    /databases/(default)/documents/users/$(request.auth.uid)).data.isAdmin;
 5: service firebase.storage {
 6:   match /b/{bucket}/o {
 7:     // This rule allows anyone with your Storage bucket reference to view, edit,
 8:     // and delete all data in your Storage bucket. It is useful for getting
 9:     // started, but it is configured to expire after 30 days because it
10:     // leaves your app open to attackers. At that time, all client
11:     // requests to your Storage bucket will be denied.
12:     //
13:     // Make sure to write security rules for your app before that time, or else
14:     // all client requests to your Storage bucket will be denied until you Update
15:     // your rules
16:     match /{allPaths=**} {
17:       allow read, write: if request.time < timestamp.date(2026, 3, 29);
18:     }
19:   }
20: }
</file>

<file path="test/widget_test.dart">
 1: // This is a basic Flutter widget test.
 2: //
 3: // To perform an interaction with a widget in your test, use the WidgetTester
 4: // utility in the flutter_test package. For example, you can send tap and scroll
 5: // gestures. You can also use WidgetTester to find child widgets in the widget
 6: // tree, read text, and verify that the values of widget properties are correct.
 7: 
 8: import 'package:flutter/material.dart';
 9: import 'package:flutter_test/flutter_test.dart';
10: 
11: import 'package:lavamax/main.dart';
12: 
13: void main() {
14:   testWidgets('Counter increments smoke test', (WidgetTester tester) async {
15:     // Build our app and trigger a frame.
16:     await tester.pumpWidget(const MyApp());
17: 
18:     // Verify that our counter starts at 0.
19:     expect(find.text('0'), findsOneWidget);
20:     expect(find.text('1'), findsNothing);
21: 
22:     // Tap the '+' icon and trigger a frame.
23:     await tester.tap(find.byIcon(Icons.add));
24:     await tester.pump();
25: 
26:     // Verify that our counter has incremented.
27:     expect(find.text('0'), findsNothing);
28:     expect(find.text('1'), findsOneWidget);
29:   });
30: }
</file>

